# ===== 数据库 =====
# 本地开发（SQLite）
DATABASE_URL="file:./dev.db"

# 生产环境（Turso 云端 SQLite，在 https://turso.tech 免费创建）
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ===== NextAuth =====
# 用 `openssl rand -base64 32` 生成
AUTH_SECRET="your-auth-secret"

# ===== 邮件 SMTP（超支提醒） =====
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_email@qq.com"
SMTP_PASS="your_smtp_authorization_code"
SMTP_FROM="记账助手 <your_email@qq.com>"
